# === Required ===
# Anthropic API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Gmail 送信設定（送信元アカウント）
# アプリパスワードは https://myaccount.google.com/apppasswords で発行
GMAIL_ADDRESS=yourname@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# 受信先
RECIPIENT_EMAIL=n-kimiya@keio.jp

# Slack 通知 (Personal-bot 統合)
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL_ID=C0ATHN9K287

# === Optional ===
# Claude モデル (既定: claude-sonnet-4-5)
CLAUDE_MODEL=claude-sonnet-4-5

# タイムゾーン
TIMEZONE=Asia/Tokyo

# true でメール送信せずログ出力のみ
DRY_RUN=false

# true でローカル実行時にプレビュー HTML を out/preview.html に出力
WRITE_PREVIEW=false
